# Copy to .env before running docker compose when you need real repository access.
SKETCHBLOCK_IMAGE_TAG=local
SKETCHBLOCK_VERSION=local
SKETCHBLOCK_WEB_PORT=4512
SKETCHBLOCK_COLLAB_PORT=4513
POSTGRES_USER=sketchblock
POSTGRES_PASSWORD=sketchblock-local-change-me

APP_BASE_URL=http://localhost:4512
NEXT_PUBLIC_COLLAB_SERVER_URL=http://localhost:4513
SKETCHBLOCK_DEPLOYMENT_ENV=local
SKETCHBLOCK_AUTH_MODE=demo
SKETCHBLOCK_DEV_USER_LOGIN=local-dev
SKETCHBLOCK_DEV_USER_NAME=Local Dev User
SKETCHBLOCK_DEV_USER_PERMISSION=admin
SKETCHBLOCK_BOOTSTRAP_TOKEN=replace-with-openssl-rand-hex-32
SKETCHBLOCK_SESSION_INVITE_TTL_HOURS=168

# Use one shared secret for Web auth cookies and Collab tickets.
APP_AUTH_SECRET=local-compose-auth-secret-change-me

SKETCHBLOCK_GIT_AUTHOR_NAME=
SKETCHBLOCK_GIT_AUTHOR_EMAIL=

# Required for participant identity and real Owner repository access with SKETCHBLOCK_AUTH_MODE=github.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

COLLAB_ALLOWED_ORIGINS=http://localhost:4512
COLLAB_LOG_LEVEL=info
COLLAB_LOG_FORMAT=json
COLLAB_PERSISTENCE_DRIVER=postgres
COLLAB_DATABASE_URL=postgresql://sketchblock:sketchblock-local-change-me@postgres:5432/sketchblock_collab
COLLAB_DATABASE_POOL_MAX=5
SKETCHBLOCK_APP_PERSISTENCE_DRIVER=postgres
SKETCHBLOCK_APP_DATABASE_URL=postgresql://sketchblock:sketchblock-local-change-me@postgres:5432/sketchblock_app
SKETCHBLOCK_APP_DATABASE_POOL_MAX=5
