# Optional: Committer used for Sketchblock commits.
# Defaults to the authenticated GitHub token user if left empty.
SKETCHBLOCK_GIT_AUTHOR_NAME=
SKETCHBLOCK_GIT_AUTHOR_EMAIL=

# Secure first-run setup. Generate with: openssl rand -hex 32
# Ignored after the first Instance Owner has been created.
SKETCHBLOCK_BOOTSTRAP_TOKEN=
SKETCHBLOCK_SESSION_INVITE_TTL_HOURS=168

# GitHub OAuth identity for invited participants and repository access for the Instance Owner.
# Participants request read:user; the explicit Owner connection requests read:user and repo.
# The Owner access token is stored encrypted in an HttpOnly cookie.
# Local OAuth callback URL:
# http://localhost:4512/api/auth/github/callback
APP_BASE_URL=http://localhost:4512

# Local development can use the virtual dev user without GitHub OAuth for UI-only checks.
# Real repository selection/scan/open/save requires SKETCHBLOCK_AUTH_MODE=github, a local Owner and a fresh Owner connection.
# Production must use github; dev is rejected when SKETCHBLOCK_DEPLOYMENT_ENV=production.
SKETCHBLOCK_AUTH_MODE=dev
SKETCHBLOCK_DEPLOYMENT_ENV=local
NEXT_PUBLIC_SKETCHBLOCK_VERSION=local
SKETCHBLOCK_DEV_USER_LOGIN=local-dev
SKETCHBLOCK_DEV_USER_NAME=Local Dev User
SKETCHBLOCK_DEV_USER_PERMISSION=admin

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
APP_AUTH_SECRET=

# Optional: separate realtime collaboration server.
# Keep this aligned with apps/collab-server/.env.local.
COLLAB_SERVER_URL=http://localhost:4513
NEXT_PUBLIC_COLLAB_SERVER_URL=http://localhost:4513

# Local persistence. Run `scripts/flyway-local.sh app migrate` before starting.
SKETCHBLOCK_APP_PERSISTENCE_DRIVER=postgres
SKETCHBLOCK_APP_DATABASE_URL=postgresql://sketchblock:sketchblock-local@localhost:5432/sketchblock_app
SKETCHBLOCK_APP_DATABASE_POOL_MAX=5
